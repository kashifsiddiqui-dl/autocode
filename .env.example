# =============================================================================
# Auto Code - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# API Keys (Required)
# ---------------------------------------------------------------------------

# Anthropic API key for Claude-based medical coding
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key for text embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------

# Full connection string (used by the backend application)
DATABASE_URL=postgresql+asyncpg://autocode:dev@postgres:5432/autocode

# Individual PostgreSQL settings (used by docker-compose for the postgres service)
POSTGRES_DB=autocode
POSTGRES_USER=autocode
POSTGRES_PASSWORD=dev

# ---------------------------------------------------------------------------
# Vector Database (Qdrant)
# ---------------------------------------------------------------------------

# Qdrant connection URL
QDRANT_URL=http://qdrant:6333

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------

# Environment: development | staging | production
ENVIRONMENT=development

# Log level: debug | info | warning | error | critical
LOG_LEVEL=debug

# Backend secret key (for JWT signing, session management)
SECRET_KEY=change-me-to-a-random-string-in-production

# ---------------------------------------------------------------------------
# Frontend Settings
# ---------------------------------------------------------------------------

# Public API URL (accessible from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# AWS (Production only)
# ---------------------------------------------------------------------------

# AWS region for ECR, CloudWatch, etc.
# AWS_REGION=us-east-1

# ECR repository URI
# ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# ---------------------------------------------------------------------------
# Staging / Production Overrides
# ---------------------------------------------------------------------------

# Domain name for TLS certificate
# DOMAIN=autocode.example.com

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# Redis URL (for caching / rate limiting in production)
# REDIS_URL=redis://redis:6379/0
